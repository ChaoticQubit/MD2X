# Copy to .env and fill in your secrets, then run md2x normally.
# md2x auto-loads .env from the current directory and the project root.
# Real environment variables always win; .env is a fallback. .env is gitignored.

# --- LLM provider key: set the ONE that matches ai.model in md2x.yaml ---
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GROQ_API_KEY=
# GOOGLE_API_KEY=
# NVIDIA_API_KEY=

# OpenAI-compatible / local endpoint (ai.model: provider: openai-like):
# LOCAL_LLM_KEY=

# --- one-click deploy ---
# VERCEL_TOKEN=
